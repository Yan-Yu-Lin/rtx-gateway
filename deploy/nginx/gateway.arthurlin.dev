server {
    listen 127.0.0.1:8443 ssl http2;
    server_name gateway.arthurlin.dev;

    ssl_certificate /etc/letsencrypt/live/gateway.arthurlin.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/gateway.arthurlin.dev/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 64m;

    # Keep /api on Nuxt. Nuxt owns login/session cookies and calls the Go admin
    # API on 127.0.0.1:9189 server-side with RTX_GATEWAY_ADMIN_TOKEN.
    location /api/ {
        proxy_pass http://127.0.0.1:3008;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection "";
        proxy_request_buffering off;
        proxy_buffering off;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location / {
        proxy_pass http://127.0.0.1:3008;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection "";
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }
}
