server {
    listen 127.0.0.1:8443 ssl proxy_protocol http2;
    server_name rtx-ocr.arthurlin.dev;

    ssl_certificate /etc/letsencrypt/live/rtx-ocr.arthurlin.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/rtx-ocr.arthurlin.dev/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 64m;

    location = /health {
        proxy_pass http://127.0.0.1:9188;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection "";
        proxy_request_buffering off;
        proxy_buffering off;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location ^~ /v1/ {
        limit_req zone=rtx_unauth burst=20 nodelay;
        limit_req zone=rtx_auth burst=120 nodelay;
        proxy_pass http://127.0.0.1:9188;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection "";
        proxy_request_buffering off;
        proxy_buffering off;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location / {
        return 404;
    }
}
